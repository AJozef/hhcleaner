# Шаблон .env для hh_cleaner.
# Скопируй в .env и заполни нужные значения:
#   copy .env.example .env
#
# ВНИМАНИЕ: .env содержит пароль — он в .gitignore, никогда не коммить его.

# --- Авторизация (опционально) ---
# Если заданы, скрипт автоматически заполняет форму логина.
# Капчу и 2FA всё равно придётся пройти вручную в открывшемся браузере.
# HH_EMAIL=your@email.com
# HH_PASSWORD=yourpassword

# --- Параметры очистки (опционально) ---
# Порог в днях для шага old-chats (по умолчанию 60).
# HH_OLD_DAYS=60

# Число чатов на страницу при запросах к API (по умолчанию 50, максимум 50).
# HH_CHATS_PER_PAGE=50

# --- Тонкая настройка пауз между запросами (опционально) ---
# Паузы защищают от троттлинга API. Уменьшать осторожно.
# HH_REQUEST_PAUSE=0.2   # пауза между однотипными вызовами (удаление/чтение)
# HH_PAGE_PAUSE=0.5      # пауза между страницами пагинации
# HH_RETRY_BACKOFF=5     # пауза перед повтором упавшего запроса

# --- Каталог данных (опционально) ---
# Где хранить профиль браузера (сессию) и лог. По умолчанию ~/.hhcleaner.
# HHCLEANER_HOME=C:\path\to\hhcleaner-data
