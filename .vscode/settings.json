{
    // Использовать интерпретатор из .venv — тогда Pylance и линтеры видят
    // установленные requests/playwright и не подчёркивают импорты.
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",

    // Дефолтный режим Pylance.
    "python.analysis.typeCheckingMode": "standard"
}
