# Виртуальные окружения
.venv/
venv/
env/
ENV/

# Кэш и байткод Python
__pycache__/
*.py[cod]
*$py.class

# Настройки IDE (PyCharm)
.idea/

# Папку .vscode намеренно НЕ игнорируем: settings.json с выбором
# интерпретатора и режимом Pylance полезно хранить вместе с проектом.

# Кэши инструментов
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Профиль браузера с сессией hh.ru — секрет, даёт доступ к аккаунту
.userdata/
# Старый формат сессии (storage_state), больше не используется, но мог остаться
auth_state.json

# Переменные окружения (могут содержать пароль)
.env

# Логи и временные файлы
*.log

# Артефакты сборки и pip install -e .
*.egg-info/
build/
dist/
